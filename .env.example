# ==============================================================
# Frontend (expostas no bundle — use apenas dados públicos)
# ==============================================================
VITE_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_GA_ID=G-XXXXXXXXXX

# ==============================================================
# Backend (NUNCA usar com prefixo VITE_ — ficam no servidor)
# ==============================================================

# Supabase (service role — bypassa RLS, não expor ao frontend)
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Proteção dos crons e endpoints admin (string aleatória longa)
CRON_SECRET=troque-por-uma-string-aleatoria-longa

# ==============================================================
# Mercado Livre OAuth
# ==============================================================
ML_CLIENT_ID=123456789
ML_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ML_REDIRECT_URI=https://achadinhoslm.com.br/api/ml/oauth/callback

# Configurações opcionais dos crons ML
ML_PLATFORM_LABEL=mercadolivre
ML_PRICE_BATCH_SIZE=10
ML_PRICE_CONCURRENCY=1
ML_PRICE_MAX_RUN_MS=45000
ML_RESOLVE_MAX_ITEMS=400

# ==============================================================
# Shopee Affiliate API
# ==============================================================
SHOPEE_APP_ID=123456789
SHOPEE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPEE_API_BASE=https://open-api.affiliate.shopee.com.br

# ==============================================================
# DEPRECADO — NÃO USAR (substituído por OAuth)
# Cookies de sessão do browser ML expiram em ~7 dias e precisam
# ser atualizados manualmente. Prefira o fluxo OAuth acima.
# ==============================================================
# ML_COOKIE=
# ML_CSRF_TOKEN=
